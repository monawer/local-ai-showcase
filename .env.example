# متغيرات البناء (VITE_*) — تُحقَن في bundle الـ React وقت تشغيل `bun run build`.
# تغييرها يتطلب إعادة بناء الصورة.

# Ollama مثبّت على Windows host (خارج Docker)
VITE_OLLAMA_URL=http://localhost:11434

# n8n خلف Traefik
VITE_N8N_URL=http://n8n.localhost
VITE_N8N_WEBHOOK_BASE=http://n8n.localhost

# (اختياري) API key لقراءة قائمة workflows من n8n
VITE_N8N_API_KEY=

# Supabase (اختياري)
VITE_SUPABASE_URL=http://supabase.localhost
VITE_SUPABASE_ANON_KEY=
