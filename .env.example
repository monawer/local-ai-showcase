# متغيرات البناء (VITE_*) — تُحقَن في bundle الـ React وقت تشغيل `bun run build`.
# تغييرها يتطلب إعادة بناء الصورة.

# المسارات الافتراضية تمر عبر Nginx داخل الحاوية لتجنب CORS
VITE_OLLAMA_URL=/proxy/ollama

# n8n خلف Traefik
VITE_N8N_URL=/proxy/n8n
VITE_N8N_WEBHOOK_BASE=/proxy/n8n/webhook

# (اختياري) API key لقراءة قائمة workflows من n8n
VITE_N8N_API_KEY=

# Supabase (اختياري)
VITE_SUPABASE_URL=/proxy/supabase
VITE_SUPABASE_ANON_KEY=
